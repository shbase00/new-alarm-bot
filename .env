# ============================================================
# REQUIRED
# ============================================================
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=1925070662

# ============================================================
# OPTIONAL — Alerts
# ============================================================
# Minutes before mint to send first alert (default: 15)
ALERT_MINUTES_BEFORE=15

# Daily summary time UTC (default: 10:00)
DAILY_SUMMARY_HOUR=10
DAILY_SUMMARY_MINUTE=0

# How often the alert loop runs, in seconds (default: 60)
STATUS_CHECK_INTERVAL=60

# ============================================================
# OPTIONAL — Floor & Sweep Monitor
# ============================================================
# How often to check floor price, in seconds (default: 60)
FLOOR_CHECK_INTERVAL=60

# Floor increase % to trigger pump alert (default: 0.5 = 50%)
FLOOR_PUMP_THRESHOLD=0.5

# Number of NFTs bought in window to trigger sweep alert (default: 10)
SWEEP_COUNT_THRESHOLD=10

# Window in seconds for sweep detection (default: 60)
SWEEP_WINDOW_SECONDS=60

# ============================================================
# OPTIONAL — API Server (PC Scraper endpoint)
# ============================================================
# Secret key for POST /api/mint authentication (leave empty to disable auth)
API_SECRET_KEY=

# Port for the API server (Railway sets PORT automatically)
# API_PORT=8080

# ============================================================
# OPTIONAL — OpenSea API
# ============================================================
OPENSEA_API_KEY=3cc93335d0f248dcb625024444f4a05d

# ============================================================
# DATABASE — Railway Volume
# ============================================================
DATABASE_PATH=/data/alarm.db
