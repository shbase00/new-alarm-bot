# ============================================================
# NFT Mint Alarm Bot - Node.js - Environment Variables
# ============================================================

# ----- Telegram -----
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321          # Comma-separated admin Telegram user IDs

# ----- Database -----
DATABASE_PATH=/data/alarm.db           # SQLite database file path

# ----- OpenSea -----
OPENSEA_API_KEY=your_opensea_api_key   # Get from https://docs.opensea.io/

# ----- Blockchain -----
ETHERSCAN_API_KEY=your_etherscan_key   # Etherscan V2 API key (multi-chain)
ABSCAN_API_KEY=your_abscan_key         # Abstract chain explorer key (optional)
INFURA_API_KEY=your_infura_key         # Infura for RPC (optional, fallback)
ALCHEMY_API_KEY=your_alchemy_key       # Alchemy for RPC (optional, fallback)

# ----- Alert Settings -----
ALERT_MINUTES_BEFORE=15                # Minutes before mint to send pre-alert
DAILY_SUMMARY_HOUR=10                  # Hour (UTC) to send daily summary
DAILY_SUMMARY_MINUTE=0

# ----- Floor & Sweep Detection -----
FLOOR_PUMP_THRESHOLD=0.5               # 50% increase triggers floor pump alert
SWEEP_COUNT_THRESHOLD=10               # NFTs bought in window = sweep alert
SWEEP_WINDOW_SECONDS=60                # Time window for sweep detection

# ----- Scraping -----
CHROME_PATH=/usr/bin/chromium          # Path to Chromium/Chrome binary
CHROME_BIN=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true           # Skip bundled Chromium download

# ----- API Server -----
API_PORT=3000                          # Internal API server port
API_SECRET_KEY=                        # Optional secret key for /api/mint endpoint

# ----- Railway / Deployment -----
PORT=3000                              # Railway injects this
RAILWAY_ENVIRONMENT=production         # Set automatically by Railway

# ----- Logging -----
LOG_LEVEL=info                         # debug | info | warn | error
